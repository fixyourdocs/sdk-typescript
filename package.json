{
  "name": "@fixyourdocs/sdk",
  "version": "0.3.0",
  "description": "Reference TypeScript SDK for the Docs Feedback Protocol",
  "license": "Apache-2.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "fixyourdocs": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "publint": "publint",
    "attw": "attw --pack ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fixyourdocs/sdk-typescript.git"
  },
  "homepage": "https://docsfeedback.org",
  "bugs": "https://github.com/fixyourdocs/sdk-typescript/issues",
  "keywords": [
    "docs",
    "documentation",
    "agents",
    "ai",
    "feedback",
    "protocol"
  ],
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.0",
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.19.41",
    "eslint": "^9.0.0",
    "msw": "^2.4.0",
    "publint": "^0.2.0",
    "tsd": "^0.31.0",
    "tsup": "^8.3.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  }
}
